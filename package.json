{
  "name": "digist",
  "version": "0.1.0",
  "description": "AI self-evolution information digestion engine",
  "type": "module",
  "bin": {
    "digist": "./bin/digist"
  },
  "exports": {
    ".": "./dist/index.js",
    "./crawl-api": "./dist/api/crawl-api.js",
    "./preprocess": "./dist/api/preprocess.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "postinstall": "bash scripts/postinstall-native.sh",
    "scrape": "bash bin/digist scrape",
    "digist-api": "tsx src/api/server.ts",
    "digist-api:watch": "tsx watch src/api/server.ts",
    "summarize": "tsx scripts/summarize-daily.ts",
    "sync-knowlever": "tsx scripts/sync-digest-to-knowlever.ts",
    "test": "tsx test-edge.ts && tsx test-all.ts && tsx test-scrapers.ts && tsx test-perf.ts",
    "test:edge": "tsx test-edge.ts",
    "test:all": "tsx test-all.ts",
    "test:scrapers": "tsx test-scrapers.ts",
    "test:perf": "tsx test-perf.ts",
    "test:l1": "tsx tests/l1-collection.qa.ts",
    "test:l3": "tsx tests/l3-selfheal.qa.ts"
  },
  "dependencies": {
    "@mendable/firecrawl-js": "^1.29.3",
    "axios": "^1.18.1",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "nanoid": "^5.1.16",
    "node-cron": "^3.0.3",
    "turndown": "^7.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.20.1",
    "@types/node-cron": "^3.0.0",
    "@types/turndown": "^5.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "patchright": "^1.61.1"
  }
}
